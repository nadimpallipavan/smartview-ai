# SmartView AI Environment Variables
# Copy this file to .env and fill in your values

# Rails
SECRET_KEY_BASE=your_secret_key_base_here_generate_with_rails_secret
RAILS_ENV=development
RAILS_MASTER_KEY=

# Database
DATABASE_URL=postgres://smartview:smartview@postgres:5432/smartview_development

# Redis
REDIS_URL=redis://redis:6379/0

# AWS S3 (for Active Storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=smartview-media

# AWS CloudFront CDN
CLOUDFRONT_DISTRIBUTION_ID=
CLOUDFRONT_DOMAIN=

# AWS Rekognition (for Face Recognition)
AWS_REKOGNITION_COLLECTION_ID=smartview_faces
# Set to 'true' to use mock face recognition (no AWS needed)
FACE_RECOGNITION_MOCK=true

# Sidekiq
SIDEKIQ_CONCURRENCY=5
