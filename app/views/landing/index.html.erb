<% content_for :title, "Welcome" %>
<% provide(:layout, "landing") %>

<!-- Hero Section -->
<div class="relative min-h-screen flex flex-col">
  <!-- Gradient Background -->
  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-sv-darker via-[#0d0d1a] to-sv-darker"></div>
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-sv-primary/20 rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-sv-secondary/15 rounded-full blur-3xl"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-sv-accent/5 rounded-full blur-3xl"></div>
  </div>

  <!-- Navbar -->
  <nav class="relative z-10 flex items-center justify-between px-6 lg:px-12 py-6">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-sv-primary to-sv-secondary flex items-center justify-center shadow-glow-sm">
        <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
        </svg>
      </div>
      <div>
        <span class="text-2xl font-bold bg-gradient-to-r from-sv-primary-light to-sv-secondary bg-clip-text text-transparent">SmartView</span>
        <span class="text-sm text-sv-primary-light font-semibold ml-1">AI</span>
      </div>
    </div>
    <div class="flex items-center gap-4">
      <%= link_to "Sign In", new_user_session_path, class: "sv-btn-ghost text-sv-text font-medium" %>
      <%= link_to "Get Started", new_user_registration_path, class: "sv-btn-primary text-sm px-5 py-2.5" %>
    </div>
  </nav>

  <!-- Hero Content -->
  <div class="relative z-10 flex-1 flex flex-col items-center justify-center text-center px-6 py-20">
    <div class="animate-fade-in">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-sv-primary/10 border border-sv-primary/20 text-sv-primary-light text-sm font-medium mb-8">
        <span class="w-2 h-2 bg-sv-primary rounded-full animate-pulse"></span>
        AI-Powered Smart TV Platform
      </div>

      <h1 class="text-5xl lg:text-7xl font-black text-white mb-6 leading-tight">
        The Future of
        <span class="bg-gradient-to-r from-sv-primary-light via-sv-secondary to-sv-accent bg-clip-text text-transparent block">
          Smart Streaming
        </span>
      </h1>

      <p class="text-xl text-sv-text-muted max-w-2xl mx-auto mb-10 leading-relaxed">
        Watch live TV, on-demand movies and series with AI-driven recommendations,
        facial recognition profile switching, and simultaneous multi-screen playback.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <%= link_to "Start Watching Free", new_user_registration_path, class: "sv-btn-primary text-base px-8 py-4" %>
        <%= link_to "Sign In", new_user_session_path, class: "sv-btn-secondary text-base px-8 py-4" %>
      </div>
    </div>

    <!-- Preview mockup -->
    <div class="mt-20 w-full max-w-5xl mx-auto animate-slide-up">
      <div class="relative rounded-2xl overflow-hidden border border-sv-border/50 shadow-2xl bg-sv-darker">
        <div class="flex items-center gap-2 px-4 py-3 bg-sv-card border-b border-sv-border">
          <div class="w-3 h-3 rounded-full bg-red-500/70"></div>
          <div class="w-3 h-3 rounded-full bg-yellow-500/70"></div>
          <div class="w-3 h-3 rounded-full bg-green-500/70"></div>
          <span class="ml-2 text-xs text-sv-text-muted">smartview.ai/dashboard</span>
        </div>
        <div class="p-8 bg-gradient-to-br from-sv-darker to-[#0d0d20]">
          <div class="grid grid-cols-4 gap-3">
            <% 8.times do |i| %>
              <div class="rounded-lg overflow-hidden aspect-[2/3] bg-gradient-to-br <%= ['from-indigo-900 to-purple-800','from-cyan-900 to-blue-800','from-rose-900 to-pink-800','from-emerald-900 to-teal-800'].rotate(i).first %> opacity-80 flex items-end p-2">
                <div class="w-full h-1.5 bg-white/20 rounded-full"><div class="h-full bg-sv-primary rounded-full" style="width: <%= [30,60,90,45,75,20,55,85].rotate(i).first %>%"></div></div>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Features Section -->
<div class="relative bg-sv-darker py-24 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold text-white mb-4">Everything You Need</h2>
      <p class="text-sv-text-muted text-lg max-w-2xl mx-auto">A complete intelligent streaming platform built with cutting-edge technology</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <!-- Feature 1 -->
      <div class="sv-card p-6 group">
        <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-sv-primary to-indigo-700 flex items-center justify-center mb-4 group-hover:shadow-glow-sm transition-shadow">
          <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-white mb-2">AI Recommendations</h3>
        <p class="text-sv-text-muted">Collaborative filtering engine analyzes your viewing habits to surface content you'll love, refreshed automatically via background jobs.</p>
      </div>

      <!-- Feature 2 -->
      <div class="sv-card p-6 group">
        <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-sv-secondary to-blue-600 flex items-center justify-center mb-4 group-hover:shadow-glow-sm transition-shadow">
          <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-white mb-2">Face Recognition Login</h3>
        <p class="text-sv-text-muted">Auto-switch profiles using your webcam. Powered by AWS Rekognition with an offline mock mode for development.</p>
      </div>

      <!-- Feature 3 -->
      <div class="sv-card p-6 group">
        <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-sv-accent to-pink-600 flex items-center justify-center mb-4 group-hover:shadow-glow-sm transition-shadow">
          <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1H5a1 1 0 01-1-1V5zm10 0a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1h-4a1 1 0 01-1-1V5zM4 15a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1H5a1 1 0 01-1-1v-4zm10 0a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1h-4a1 1 0 01-1-1v-4z"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-white mb-2">Multi-Screen Playback</h3>
        <p class="text-sv-text-muted">Watch up to 5 live streams simultaneously in a responsive grid layout. Perfect for sports events and news monitoring.</p>
      </div>

      <!-- Feature 4 -->
      <div class="sv-card p-6 group">
        <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-sv-success to-teal-600 flex items-center justify-center mb-4 group-hover:shadow-glow-sm transition-shadow">
          <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.636 18.364a9 9 0 010-12.728m12.728 0a9 9 0 010 12.728m-9.9-2.829a5 5 0 010-7.07m7.072 0a5 5 0 010 7.07M13 12a1 1 0 11-2 0 1 1 0 012 0z"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-white mb-2">HLS Live Streaming</h3>
        <p class="text-sv-text-muted">Full HLS playback support via hls.js with automatic quality adaptation, low-latency mode, and error recovery.</p>
      </div>

      <!-- Feature 5 -->
      <div class="sv-card p-6 group">
        <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-sv-warning to-orange-600 flex items-center justify-center mb-4 group-hover:shadow-glow-sm transition-shadow">
          <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-white mb-2">Multiple Profiles</h3>
        <p class="text-sv-text-muted">Create separate profiles for each household member with individual watch history, preferences, and personalized recommendations.</p>
      </div>

      <!-- Feature 6 -->
      <div class="sv-card p-6 group">
        <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-purple-600 to-violet-700 flex items-center justify-center mb-4 group-hover:shadow-glow-sm transition-shadow">
          <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-white mb-2">Encrypted & Secure</h3>
        <p class="text-sv-text-muted">Face embeddings encrypted with AES-256 via Active Record Encryption. Secure session management with Devise authentication.</p>
      </div>
    </div>
  </div>
</div>

<!-- CTA Section -->
<div class="relative bg-sv-dark py-24 px-6 overflow-hidden">
  <div class="absolute inset-0">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[400px] bg-gradient-to-r from-sv-primary/10 to-sv-secondary/10 rounded-full blur-3xl"></div>
  </div>
  <div class="relative z-10 max-w-3xl mx-auto text-center">
    <h2 class="text-4xl font-bold text-white mb-6">Ready to Watch Smarter?</h2>
    <p class="text-sv-text-muted text-lg mb-10">Join SmartView AI and experience the next generation of intelligent streaming.</p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <%= link_to "Create Free Account", new_user_registration_path, class: "sv-btn-primary text-base px-10 py-4" %>
    </div>
    <p class="text-sv-text-muted text-sm mt-6">No credit card required. Start streaming instantly.</p>
  </div>
</div>

<!-- Footer -->
<footer class="bg-sv-darker border-t border-sv-border px-6 py-8">
  <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
    <div class="flex items-center gap-2">
      <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-sv-primary to-sv-secondary flex items-center justify-center">
        <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
        </svg>
      </div>
      <span class="text-sv-text-muted text-sm font-medium">SmartView AI &copy; <%= Time.current.year %></span>
    </div>
    <p class="text-sv-text-muted text-sm">Built with Ruby on Rails 7 + Hotwire + Tailwind CSS</p>
  </div>
</footer>
