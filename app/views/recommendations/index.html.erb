<% content_for :title, "Recommendations" %>

<div class="p-6">
  <!-- Header -->
  <div class="flex items-start gap-4 mb-8">
    <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-sv-primary to-sv-secondary flex items-center justify-center flex-shrink-0">
      <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
      </svg>
    </div>
    <div class="flex-1">
      <h1 class="text-2xl font-bold text-white">Recommended for You</h1>
      <p class="text-sv-text-muted text-sm mt-0.5">
        AI-powered picks for <strong class="text-sv-text"><%= @profile.name %></strong> based on your viewing history
      </p>
    </div>
  </div>

  <!-- How It Works -->
  <div class="sv-card p-4 mb-8 flex items-start gap-4">
    <svg class="w-5 h-5 text-sv-secondary flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
    </svg>
    <div>
      <p class="text-sv-text text-sm font-medium">About Your Recommendations</p>
      <p class="text-sv-text-muted text-xs mt-1">
        These picks are generated by our item-based collaborative filtering engine using cosine similarity over your viewing history.
        Recommendations refresh automatically every hour via background jobs.
      </p>
    </div>
  </div>

  <!-- Recommendations Grid -->
  <% if @recommendations.any? %>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-5">
      <% @recommendations.each do |rec| %>
        <div class="group">
          <%= link_to player_path(rec.content), class: "sv-poster-card block" do %>
            <div class="aspect-[2/3] bg-sv-card rounded-xl overflow-hidden relative">
              <img src="<%= rec.content.poster_url %>" alt="<%= rec.content.title %>"
                   class="w-full h-full object-cover"
                   loading="lazy"
                   onerror="this.src='https://via.placeholder.com/200x300/12121a/6366f1?text=<%= CGI.escape(rec.content.title[0..8]) %>'">
              <!-- Score indicator -->
              <div class="absolute top-2 right-2">
                <div class="w-8 h-8 rounded-full bg-black/70 flex items-center justify-center">
                  <div class="w-5 h-5 rounded-full border-2 border-sv-primary"
                       style="background: conic-gradient(#6366f1 <%= (rec.score * 360).round %>deg, transparent 0deg)">
                  </div>
                </div>
              </div>
              <div class="sv-poster-overlay">
                <p class="text-white font-semibold text-sm line-clamp-2"><%= rec.content.title %></p>
                <div class="flex items-center gap-2 mt-1">
                  <% if rec.content.rating %>
                    <span class="text-sv-warning text-xs">&#9733; <%= rec.content.rating %></span>
                  <% end %>
                  <span class="text-sv-text-muted text-xs"><%= rec.content.genre %></span>
                </div>
              </div>
            </div>
          <% end %>

          <div class="mt-2 px-0.5">
            <p class="text-sv-text text-sm font-medium line-clamp-1"><%= rec.content.title %></p>
            <p class="text-sv-text-muted text-xs line-clamp-1 mt-0.5 italic"><%= rec.reason %></p>
            <div class="flex items-center gap-2 mt-1">
              <span class="text-xs text-sv-text-muted"><%= rec.content.year %></span>
              <span class="text-xs text-sv-text-muted">&middot;</span>
              <span class="text-xs text-sv-text-muted"><%= rec.content.formatted_duration %></span>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-20">
      <div class="w-20 h-20 rounded-full bg-sv-primary/10 flex items-center justify-center mx-auto mb-4">
        <svg class="w-10 h-10 text-sv-primary-light" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
        </svg>
      </div>
      <h3 class="text-xl font-bold text-white mb-2">No recommendations yet</h3>
      <p class="text-sv-text-muted max-w-md mx-auto">
        Start watching content to build your taste profile.
        Our AI will generate personalized picks after you watch a few titles.
      </p>
      <div class="flex gap-3 justify-center mt-6">
        <%= link_to "Browse Catalog", contents_path, class: "sv-btn-primary text-sm" %>
        <%= link_to "Watch Live TV", streams_path, class: "sv-btn-secondary text-sm" %>
      </div>
    </div>
  <% end %>
</div>
