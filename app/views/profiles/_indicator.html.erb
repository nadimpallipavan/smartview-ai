<div id="profile-indicator">
  <% if profile %>
    <%= link_to profiles_path, class: "flex items-center gap-3 w-full p-2 rounded-xl hover:bg-sv-card transition-all group" do %>
      <div class="sv-profile-avatar bg-gradient-to-br <%= profile.avatar_gradient %> w-9 h-9 text-sm flex-shrink-0">
        <% if profile.avatar.attached? %>
          <%= image_tag profile.avatar, class: "w-full h-full object-cover rounded-full" %>
        <% else %>
          <%= profile.initials %>
        <% end %>
      </div>
      <div class="flex-1 min-w-0">
        <p class="text-sm font-semibold text-sv-text truncate group-hover:text-white transition-colors"><%= profile.name %></p>
        <p class="text-xs text-sv-text-muted">Switch Profile</p>
      </div>
      <svg class="w-4 h-4 text-sv-text-muted flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l4-4 4 4m0 6l-4 4-4-4"/>
      </svg>
    <% end %>
  <% else %>
    <%= link_to profiles_path, class: "flex items-center gap-2 text-sv-text-muted hover:text-sv-text text-sm p-2 rounded-xl hover:bg-sv-card transition-all" do %>
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
      </svg>
      Select Profile
    <% end %>
  <% end %>
</div>
