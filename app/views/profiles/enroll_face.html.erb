<% content_for :title, "Enroll Face — #{@profile.name}" %>

<div class="max-w-lg mx-auto p-6">
  <div class="mb-6">
    <%= link_to profile_path(@profile), class: "text-sv-text-muted hover:text-sv-text text-sm flex items-center gap-1 transition-colors" do %>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      Back to Profile
    <% end %>
  </div>

  <div class="sv-card p-8">
    <div class="flex items-center gap-4 mb-6">
      <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-sv-primary to-sv-secondary flex items-center justify-center">
        <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
        </svg>
      </div>
      <div>
        <h1 class="text-xl font-bold text-white">Face Enrollment</h1>
        <p class="text-sv-text-muted text-sm">for <strong class="text-sv-text"><%= @profile.name %></strong></p>
      </div>
    </div>

    <% if @face_embedding&.enrolled? %>
      <div class="flex items-center gap-2 px-4 py-3 bg-sv-success/10 border border-sv-success/30 rounded-xl text-sv-success text-sm mb-6">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
        Face already enrolled — you can re-enroll below to update it
      </div>
    <% end %>

    <!-- Instructions -->
    <div class="bg-sv-primary/5 border border-sv-primary/20 rounded-xl p-4 mb-6">
      <h3 class="text-sm font-semibold text-sv-primary-light mb-2">How it works</h3>
      <ul class="text-sv-text-muted text-xs space-y-1">
        <li>1. Allow camera access when prompted</li>
        <li>2. Position your face within the guide circle</li>
        <li>3. Click "Capture Photo" to take a snapshot</li>
        <li>4. Preview the image, then click "Enroll Face"</li>
        <li>5. Face recognition will then auto-switch to this profile on login</li>
      </ul>
    </div>

    <!-- Webcam Component -->
    <div data-controller="webcam" data-webcam-mode-value="enroll" data-webcam-profile-id-value="<%= @profile.id %>">
      <!-- Camera Feed -->
      <div class="relative rounded-xl overflow-hidden bg-black mb-4" style="aspect-ratio: 4/3;">
        <video data-webcam-target="video" autoplay playsinline muted class="w-full h-full object-cover"></video>
        <canvas data-webcam-target="canvas" class="hidden"></canvas>
        <!-- Face guide overlay -->
        <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
          <div class="w-48 h-60 border-2 border-sv-primary/60 rounded-full"></div>
          <div class="absolute top-3 left-3 w-6 h-6 border-t-2 border-l-2 border-sv-primary rounded-tl-lg"></div>
          <div class="absolute top-3 right-3 w-6 h-6 border-t-2 border-r-2 border-sv-primary rounded-tr-lg"></div>
          <div class="absolute bottom-3 left-3 w-6 h-6 border-b-2 border-l-2 border-sv-primary rounded-bl-lg"></div>
          <div class="absolute bottom-3 right-3 w-6 h-6 border-b-2 border-r-2 border-sv-primary rounded-br-lg"></div>
        </div>
      </div>

      <!-- Status Message -->
      <p data-webcam-target="status" class="text-sv-secondary text-sm text-center mb-4">Starting camera...</p>

      <!-- Preview -->
      <div class="mb-4 hidden" id="preview-container">
        <p class="text-sv-text-muted text-xs mb-2">Captured photo:</p>
        <img data-webcam-target="preview" class="rounded-xl w-full hidden" alt="Captured face">
      </div>

      <!-- Enrollment Form -->
      <%= form_with url: capture_face_profile_path(@profile), method: :post,
          data: { turbo_stream: true }, class: "space-y-3" do |f| %>
        <input type="hidden" data-webcam-target="imageData" name="face_image" id="face_image_data">

        <div class="flex gap-3">
          <button type="button" data-action="click->webcam#capture"
                  class="sv-btn-secondary flex-1 flex items-center justify-center gap-2 text-sm">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            Capture Photo
          </button>

          <%= f.submit "Enroll Face", class: "sv-btn-primary flex-1 text-sm cursor-pointer" %>
        </div>

        <button type="button" data-action="click->webcam#retake"
                class="sv-btn-ghost w-full text-sm">
          Retake
        </button>
      <% end %>

      <!-- Status area for Turbo Stream updates -->
      <div id="face-enrollment-status"></div>
    </div>
  </div>
</div>
