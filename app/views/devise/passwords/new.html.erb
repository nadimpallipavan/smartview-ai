<% content_for :title, "Forgot Password" %>

<h2 class="text-2xl font-bold text-white mb-2">Forgot your password?</h2>
<p class="text-sv-text-muted text-sm mb-6">Enter your email and we'll send you reset instructions.</p>

<%= form_for(resource, as: resource_name, url: password_path(resource_name),
    html: { method: :post, class: "space-y-4" }) do |f| %>
  <div>
    <%= f.label :email, "Email address", class: "block text-sm font-medium text-sv-text mb-1.5" %>
    <%= f.email_field :email, autofocus: true, autocomplete: "email",
        class: "sv-input",
        placeholder: "you@example.com" %>
  </div>

  <%= f.submit "Send Reset Instructions", class: "sv-btn-primary w-full cursor-pointer text-center" %>
<% end %>

<div class="mt-6 text-center">
  <%= link_to "Back to Sign In", new_session_path(resource_name), class: "text-sv-primary-light hover:text-sv-primary text-sm transition-colors" %>
</div>
