<% content_for :title, "Reset Password" %>

<h2 class="text-2xl font-bold text-white mb-2">Reset your password</h2>
<p class="text-sv-text-muted text-sm mb-6">Choose a new secure password for your account.</p>

<%= form_for(resource, as: resource_name, url: password_path(resource_name),
    html: { method: :put, class: "space-y-4" }) do |f| %>
  <%= f.hidden_field :reset_password_token %>

  <% if resource.errors.any? %>
    <div class="px-4 py-3 bg-sv-accent/10 border border-sv-accent/30 rounded-xl text-sv-accent text-sm space-y-1">
      <% resource.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div>
    <%= f.label :password, "New Password", class: "block text-sm font-medium text-sv-text mb-1.5" %>
    <%= f.password_field :password, autofocus: true, autocomplete: "new-password",
        class: "sv-input",
        placeholder: "At least 6 characters" %>
    <% if @minimum_password_length %>
      <p class="text-xs text-sv-text-muted mt-1">Minimum <%= @minimum_password_length %> characters</p>
    <% end %>
  </div>

  <div>
    <%= f.label :password_confirmation, "Confirm New Password", class: "block text-sm font-medium text-sv-text mb-1.5" %>
    <%= f.password_field :password_confirmation, autocomplete: "new-password",
        class: "sv-input",
        placeholder: "••••••••" %>
  </div>

  <%= f.submit "Reset Password", class: "sv-btn-primary w-full cursor-pointer text-center" %>
<% end %>
