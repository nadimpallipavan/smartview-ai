<% content_for :title, "#{@genre} — Genre" %>

<div class="p-6">
  <div class="flex items-center gap-4 mb-6">
    <span class="text-4xl"><%= genre_icon(@genre) %></span>
    <div>
      <h1 class="text-2xl font-bold text-white"><%= @genre %></h1>
      <p class="text-sv-text-muted text-sm">
        <% if @pagy %>
          <%= @pagy.count %> title<%= @pagy.count == 1 ? "" : "s" %>
        <% end %>
      </p>
    </div>
  </div>

  <!-- Genre Filter Row -->
  <div class="flex flex-wrap gap-2 mb-6">
    <% Content::GENRES.each do |genre| %>
      <%= link_to genre_contents_path(name: genre),
          class: "px-3 py-1.5 rounded-full text-sm font-medium transition-all #{ genre == @genre ? 'bg-sv-primary text-white' : 'bg-sv-card text-sv-text-muted hover:bg-sv-card-hover hover:text-sv-text border border-sv-border' }" do %>
        <%= genre_icon(genre) %> <%= genre %>
      <% end %>
    <% end %>
  </div>

  <% if @contents.any? %>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4 mb-8">
      <% @contents.each do |content| %>
        <%= render "contents/content_card", content: content %>
      <% end %>
    </div>

    <% if @pagy && @pagy.pages > 1 %>
      <div class="flex items-center justify-center gap-2">
        <% if @pagy.prev %>
          <%= link_to "&larr; Previous".html_safe, genre_contents_path(name: @genre, page: @pagy.prev), class: "sv-btn-secondary text-sm" %>
        <% end %>
        <span class="text-sv-text-muted text-sm">Page <%= @pagy.page %> of <%= @pagy.pages %></span>
        <% if @pagy.next %>
          <%= link_to "Next &rarr;".html_safe, genre_contents_path(name: @genre, page: @pagy.next), class: "sv-btn-secondary text-sm" %>
        <% end %>
      </div>
    <% end %>
  <% else %>
    <div class="text-center py-20">
      <span class="text-5xl block mb-4"><%= genre_icon(@genre) %></span>
      <h3 class="text-xl font-bold text-white mb-2">No <%= @genre %> content yet</h3>
      <p class="text-sv-text-muted">Check back soon or browse other genres.</p>
      <%= link_to "Browse Catalog", contents_path, class: "sv-btn-primary mt-4 text-sm" %>
    </div>
  <% end %>
</div>
