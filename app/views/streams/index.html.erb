<% content_for :title, "Live TV" %>

<div class="p-6">
  <div class="flex flex-col lg:flex-row lg:items-center gap-4 mb-6">
    <div>
      <div class="flex items-center gap-3 mb-1">
        <h1 class="text-2xl font-bold text-white">Live TV</h1>
        <span class="sv-badge-live">&#9679; LIVE</span>
      </div>
      <p class="text-sv-text-muted text-sm"><%= @streams.respond_to?(:count) ? @streams.count : 0 %> channels available</p>
    </div>

    <!-- Multi-screen link -->
    <%= link_to multiscreen_path, class: "lg:ml-auto sv-btn-secondary flex items-center gap-2 text-sm" do %>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1H5a1 1 0 01-1-1V5zm10 0a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1h-4a1 1 0 01-1-1V5zM4 15a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1H5a1 1 0 01-1-1v-4zm10 0a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1h-4a1 1 0 01-1-1v-4z"/>
      </svg>
      Multi-Screen View
    <% end %>
  </div>

  <!-- Category Tabs -->
  <div class="flex flex-wrap gap-2 mb-6">
    <%= link_to streams_path, class: "px-4 py-2 rounded-full text-sm font-medium transition-all #{ params[:category].blank? ? 'bg-sv-primary text-white' : 'bg-sv-card text-sv-text-muted hover:bg-sv-card-hover border border-sv-border' }" do %>
      All Channels
    <% end %>
    <% @categories.each do |category| %>
      <%= link_to streams_path(category: category),
          class: "px-4 py-2 rounded-full text-sm font-medium transition-all #{ params[:category] == category ? 'bg-sv-primary text-white' : 'bg-sv-card text-sv-text-muted hover:bg-sv-card-hover border border-sv-border' }" do %>
        <%= category %>
      <% end %>
    <% end %>
  </div>

  <!-- Channels Grid -->
  <% if @streams.any? %>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4">
      <% @streams.each do |stream| %>
        <%= link_to stream_path(stream), class: "sv-card p-4 flex flex-col items-center text-center group" do %>
          <!-- Channel Logo -->
          <div class="w-16 h-16 rounded-xl bg-sv-primary/10 border border-sv-border flex items-center justify-center mb-3 group-hover:border-sv-primary/50 group-hover:bg-sv-primary/20 transition-all overflow-hidden">
            <% if stream.logo.attached? %>
              <%= image_tag stream.logo, class: "w-full h-full object-cover" %>
            <% else %>
              <span class="text-2xl font-bold text-sv-primary-light"><%= stream.name[0..1].upcase %></span>
            <% end %>
          </div>

          <!-- Channel number -->
          <% if stream.channel_number %>
            <span class="text-xs text-sv-text-muted mb-1">CH <%= stream.channel_number %></span>
          <% end %>

          <p class="text-sv-text text-sm font-medium line-clamp-1 group-hover:text-white transition-colors"><%= stream.name %></p>
          <p class="text-sv-text-muted text-xs mt-0.5"><%= stream.category %></p>

          <div class="flex items-center gap-1.5 mt-2">
            <% if stream.is_live %>
              <span class="sv-badge-live text-xs">LIVE</span>
            <% else %>
              <span class="sv-badge bg-sv-card text-sv-text-muted text-xs">Offline</span>
            <% end %>
            <% if stream.viewer_count&.positive? %>
              <span class="text-sv-text-muted text-xs"><%= stream.viewer_count %> watching</span>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-20">
      <svg class="w-16 h-16 text-sv-text-muted mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.636 18.364a9 9 0 010-12.728m12.728 0a9 9 0 010 12.728m-9.9-2.829a5 5 0 010-7.07m7.072 0a5 5 0 010 7.07M13 12a1 1 0 11-2 0 1 1 0 012 0z"/>
      </svg>
      <h3 class="text-xl font-bold text-white mb-2">No channels available</h3>
      <p class="text-sv-text-muted">
        <% if params[:category].present? %>
          No channels in this category. <a href="<%= streams_path %>" class="text-sv-primary-light hover:underline">View all channels</a>
        <% else %>
          Live channels will appear here once added by an admin.
        <% end %>
      </p>
    </div>
  <% end %>
</div>
