<% content_for :title, @stream.name %>

<div class="p-6">
  <!-- Player -->
  <div class="max-w-5xl mx-auto">
    <div class="mb-4">
      <%= link_to streams_path, class: "text-sv-text-muted hover:text-sv-text text-sm flex items-center gap-1 transition-colors" do %>
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        All Channels
      <% end %>
    </div>

    <!-- Stream Player -->
    <div class="sv-card overflow-hidden"
         data-controller="hls-player"
         data-hls-player-url-value="<%= @stream.hls_url %>">
      <div class="relative group bg-black aspect-video">
        <video data-hls-player-target="video"
               class="w-full h-full"
               controls
               playsinline>
        </video>

        <!-- Loading Spinner -->
        <div data-hls-player-target="loading"
             class="absolute inset-0 flex items-center justify-center bg-black/50">
          <div class="w-12 h-12 border-4 border-sv-primary border-t-transparent rounded-full animate-spin"></div>
        </div>

        <!-- Stream Info Overlay -->
        <div class="absolute top-4 left-4 flex items-center gap-2">
          <% if @stream.is_live %>
            <span class="sv-badge-live text-xs px-2 py-1">&#9679; LIVE</span>
          <% end %>
          <span class="px-2 py-1 bg-black/70 rounded text-xs text-sv-text"><%= @stream.name %></span>
        </div>

        <% if @stream.viewer_count&.positive? %>
          <div class="absolute top-4 right-4">
            <span class="px-2 py-1 bg-black/70 rounded text-xs text-sv-text-muted flex items-center gap-1">
              <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M10 12a2 2 0 100-4 2 2 0 000 4z"/><path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"/></svg>
              <%= @stream.viewer_count %> watching
            </span>
          </div>
        <% end %>
      </div>

      <!-- Stream Info Bar -->
      <div class="p-4 flex items-center gap-4">
        <div class="w-10 h-10 rounded-lg bg-sv-primary/10 border border-sv-border flex items-center justify-center flex-shrink-0">
          <span class="text-sm font-bold text-sv-primary-light"><%= @stream.name[0..1].upcase %></span>
        </div>
        <div class="flex-1 min-w-0">
          <h1 class="text-white font-bold"><%= @stream.name %></h1>
          <p class="text-sv-text-muted text-sm"><%= @stream.category %><% if @stream.channel_number %> &middot; CH <%= @stream.channel_number %><% end %></p>
        </div>
        <%= link_to multiscreen_path(stream_ids: [@stream.id]), class: "sv-btn-ghost text-sm flex items-center gap-1.5" do %>
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1H5a1 1 0 01-1-1V5zm10 0a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1h-4a1 1 0 01-1-1V5zM4 15a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1H5a1 1 0 01-1-1v-4zm10 0a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1h-4a1 1 0 01-1-1v-4z"/></svg>
          Multi-Screen
        <% end %>
      </div>
    </div>

    <% if @stream.description.present? %>
      <div class="sv-card p-4 mt-4">
        <p class="text-sv-text-muted text-sm leading-relaxed"><%= @stream.description %></p>
      </div>
    <% end %>

    <!-- Related Channels -->
    <% if @related_streams.any? %>
      <div class="mt-8">
        <h2 class="text-lg font-bold text-white mb-4">More <%= @stream.category %> Channels</h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-3">
          <% @related_streams.each do |stream| %>
            <%= link_to stream_path(stream), class: "sv-card p-3 flex flex-col items-center text-center group" do %>
              <div class="w-10 h-10 rounded-lg bg-sv-primary/10 border border-sv-border flex items-center justify-center mb-2 group-hover:border-sv-primary/40 transition-colors">
                <span class="text-sm font-bold text-sv-primary-light"><%= stream.name[0..1].upcase %></span>
              </div>
              <p class="text-sv-text text-xs font-medium line-clamp-1"><%= stream.name %></p>
              <% if stream.is_live %><span class="sv-badge-live text-xs mt-1">LIVE</span><% end %>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
