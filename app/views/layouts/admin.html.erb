<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <title><%= page_title("Admin — #{yield(:title)}") %></title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
</head>
<body class="h-full bg-sv-dark">
  <div class="flex h-screen">
    <!-- Admin Sidebar -->
    <aside class="w-64 bg-sv-darker border-r border-sv-border flex flex-col">
      <div class="p-6">
        <a href="<%= admin_root_path %>" class="text-xl font-bold text-sv-primary-light">⚙ Admin Panel</a>
      </div>
      <nav class="flex-1 px-3 space-y-1">
        <a href="<%= admin_contents_path %>" class="sv-nav-link">📹 Contents</a>
        <a href="<%= admin_streams_path %>" class="sv-nav-link">📡 Streams</a>
        <a href="<%= admin_users_path %>" class="sv-nav-link">👥 Users</a>
        <div class="border-t border-sv-border my-4"></div>
        <a href="<%= dashboard_path %>" class="sv-nav-link">← Back to App</a>
      </nav>
    </aside>

    <div class="flex-1 overflow-y-auto p-8">
      <% if notice %>
        <div class="mb-4 px-4 py-3 bg-sv-success/10 border border-sv-success/30 rounded-xl text-sv-success text-sm"><%= notice %></div>
      <% end %>
      <% if alert %>
        <div class="mb-4 px-4 py-3 bg-sv-accent/10 border border-sv-accent/30 rounded-xl text-sv-accent text-sm"><%= alert %></div>
      <% end %>
      <%= yield %>
    </div>
  </div>
</body>
</html>
