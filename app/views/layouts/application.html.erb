<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <title><%= page_title(yield(:title)) %></title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="description" content="SmartView AI — Intelligent Smart TV & IPTV-OTT Streaming Platform with AI-powered recommendations and facial recognition">
  <meta name="theme-color" content="#0a0a0f">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

  <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
</head>
<body class="h-full bg-sv-dark">
  <% if user_signed_in? %>
    <div class="flex h-screen overflow-hidden">
      <!-- Sidebar Navigation -->
      <aside class="hidden lg:flex lg:flex-col w-64 bg-sv-darker border-r border-sv-border">
        <!-- Logo -->
        <div class="p-6">
          <a href="<%= dashboard_path %>" class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-sv-primary to-sv-secondary flex items-center justify-center">
              <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
              </svg>
            </div>
            <div>
              <span class="text-xl font-bold bg-gradient-to-r from-sv-primary-light to-sv-secondary bg-clip-text text-transparent">SmartView</span>
              <span class="text-xs text-sv-primary-light font-medium ml-1">AI</span>
            </div>
          </a>
        </div>

        <!-- Navigation Links -->
        <nav class="flex-1 px-3 space-y-1">
          <a href="<%= dashboard_path %>" class="sv-nav-link <%= 'active' if current_page?(dashboard_path) %>">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
            Home
          </a>
          <a href="<%= contents_path %>" class="sv-nav-link <%= 'active' if current_page?(contents_path) %>">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 4v16M17 4v16M3 8h4m10 0h4M3 12h18M3 16h4m10 0h4M4 20h16a1 1 0 001-1V5a1 1 0 00-1-1H4a1 1 0 00-1 1v14a1 1 0 001 1z"/></svg>
            Catalog
          </a>
          <a href="<%= streams_path %>" class="sv-nav-link <%= 'active' if current_page?(streams_path) %>">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.636 18.364a9 9 0 010-12.728m12.728 0a9 9 0 010 12.728m-9.9-2.829a5 5 0 010-7.07m7.072 0a5 5 0 010 7.07M13 12a1 1 0 11-2 0 1 1 0 012 0z"/></svg>
            Live TV
          </a>
          <a href="<%= multiscreen_path %>" class="sv-nav-link <%= 'active' if current_page?(multiscreen_path) %>">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1H5a1 1 0 01-1-1V5zm10 0a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1h-4a1 1 0 01-1-1V5zM4 15a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1H5a1 1 0 01-1-1v-4zm10 0a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1h-4a1 1 0 01-1-1v-4z"/></svg>
            Multi-Screen
          </a>
          <a href="<%= recommendations_path %>" class="sv-nav-link <%= 'active' if current_page?(recommendations_path) %>">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
            For You
          </a>

          <div class="pt-4 mt-4 border-t border-sv-border">
            <a href="<%= profiles_path %>" class="sv-nav-link <%= 'active' if current_page?(profiles_path) %>">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
              Profiles
            </a>
            <% if current_user&.admin? %>
              <a href="<%= admin_root_path %>" class="sv-nav-link">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                Admin
              </a>
            <% end %>
          </div>
        </nav>

        <!-- Profile Switcher -->
        <div class="p-4 border-t border-sv-border">
          <div id="profile-indicator">
            <%= render partial: "profiles/indicator", locals: { profile: current_profile } %>
          </div>
        </div>
      </aside>

      <!-- Main Content Area -->
      <div class="flex-1 flex flex-col overflow-hidden">
        <!-- Top Bar -->
        <header class="h-16 bg-sv-darker/80 backdrop-blur-xl border-b border-sv-border flex items-center justify-between px-6 z-40">
          <!-- Mobile menu button -->
          <button class="lg:hidden text-sv-text-muted hover:text-sv-text" data-controller="dropdown" data-action="click->dropdown#toggle">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
          </button>

          <!-- Search Bar -->
          <div class="flex-1 max-w-xl mx-4" data-controller="search">
            <div class="relative">
              <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-sv-text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
              <input type="text"
                     data-search-target="input"
                     data-action="input->search#search"
                     class="sv-input pl-10 bg-sv-dark"
                     placeholder="Search movies, shows, channels..."
                     id="global-search">
            </div>
          </div>

          <!-- Right side -->
          <div class="flex items-center gap-4">
            <!-- Face Recognition Toggle -->
            <button class="sv-btn-ghost text-sm" data-action="click->dropdown#toggle" title="Face Recognition">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
            </button>
            <div id="face-recognition-status" class="text-sm text-sv-text-muted"></div>

            <!-- User Menu -->
            <div class="relative" data-controller="dropdown">
              <button data-action="click->dropdown#toggle" class="flex items-center gap-2 sv-btn-ghost">
                <div class="sv-profile-avatar bg-gradient-to-br <%= current_profile&.avatar_gradient %> w-8 h-8 text-sm">
                  <%= current_profile&.initials %>
                </div>
              </button>
              <div data-dropdown-target="menu" class="hidden absolute right-0 mt-2 w-56 sv-card shadow-2xl p-2 z-50">
                <div class="px-3 py-2 text-sm text-sv-text-muted border-b border-sv-border mb-2">
                  Signed in as <strong class="text-sv-text"><%= current_user.email %></strong>
                </div>
                <a href="<%= profiles_path %>" class="block px-3 py-2 text-sm text-sv-text-muted hover:text-sv-text hover:bg-sv-card-hover rounded-lg">Manage Profiles</a>
                <a href="<%= edit_user_registration_path %>" class="block px-3 py-2 text-sm text-sv-text-muted hover:text-sv-text hover:bg-sv-card-hover rounded-lg">Account Settings</a>
                <%= link_to "Sign Out", destroy_user_session_path, data: { turbo_method: :delete }, class: "block px-3 py-2 text-sm text-sv-accent hover:bg-sv-card-hover rounded-lg" %>
              </div>
            </div>
          </div>
        </header>

        <!-- Flash Messages -->
        <% if notice %>
          <div class="mx-6 mt-4 px-4 py-3 bg-sv-success/10 border border-sv-success/30 rounded-xl text-sv-success text-sm animate-slide-up">
            <%= notice %>
          </div>
        <% end %>
        <% if alert %>
          <div class="mx-6 mt-4 px-4 py-3 bg-sv-accent/10 border border-sv-accent/30 rounded-xl text-sv-accent text-sm animate-slide-up">
            <%= alert %>
          </div>
        <% end %>

        <!-- Page Content -->
        <main id="main-content" class="flex-1 overflow-y-auto">
          <%= yield %>
        </main>
      </div>
    </div>
  <% else %>
    <%= yield %>
  <% end %>
</body>
</html>
