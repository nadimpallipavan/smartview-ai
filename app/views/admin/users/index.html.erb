<% content_for :title, "Users" %>

<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-white">Users</h1>
    <p class="text-sv-text-muted text-sm mt-0.5"><%= @pagy.count %> registered users</p>
  </div>
</div>

<div class="sv-card overflow-hidden">
  <table class="w-full">
    <thead class="border-b border-sv-border">
      <tr class="text-left">
        <th class="px-4 py-3 text-xs font-semibold text-sv-text-muted uppercase tracking-wider">User</th>
        <th class="px-4 py-3 text-xs font-semibold text-sv-text-muted uppercase tracking-wider hidden md:table-cell">Tier</th>
        <th class="px-4 py-3 text-xs font-semibold text-sv-text-muted uppercase tracking-wider hidden lg:table-cell">Profiles</th>
        <th class="px-4 py-3 text-xs font-semibold text-sv-text-muted uppercase tracking-wider hidden lg:table-cell">Joined</th>
        <th class="px-4 py-3 text-xs font-semibold text-sv-text-muted uppercase tracking-wider">Role</th>
        <th class="px-4 py-3 text-xs font-semibold text-sv-text-muted uppercase tracking-wider">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-sv-border">
      <% @users.each do |user| %>
        <tr class="hover:bg-sv-card-hover/30 transition-colors">
          <td class="px-4 py-3">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-full bg-gradient-to-br from-sv-primary to-sv-secondary flex items-center justify-center flex-shrink-0">
                <span class="text-white text-xs font-bold"><%= user.name.split.map(&:first).join.upcase[0..1] %></span>
              </div>
              <div>
                <p class="text-sv-text font-medium text-sm"><%= user.name %></p>
                <p class="text-sv-text-muted text-xs"><%= user.email %></p>
              </div>
            </div>
          </td>
          <td class="px-4 py-3 hidden md:table-cell">
            <span class="sv-badge-primary capitalize text-xs"><%= user.subscription_tier %></span>
          </td>
          <td class="px-4 py-3 text-sv-text-muted text-sm hidden lg:table-cell"><%= user.profiles.count %></td>
          <td class="px-4 py-3 text-sv-text-muted text-sm hidden lg:table-cell"><%= user.created_at.strftime("%b %d, %Y") %></td>
          <td class="px-4 py-3">
            <% if user.admin? %>
              <span class="sv-badge bg-sv-warning/20 text-sv-warning text-xs">Admin</span>
            <% else %>
              <span class="sv-badge bg-sv-card text-sv-text-muted text-xs">User</span>
            <% end %>
          </td>
          <td class="px-4 py-3">
            <div class="flex items-center gap-2">
              <%= link_to admin_user_path(user), class: "p-1.5 text-sv-text-muted hover:text-sv-text bg-sv-card hover:bg-sv-card-hover rounded-lg transition-all" do %>
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
              <% end %>
              <%= link_to edit_admin_user_path(user), class: "p-1.5 text-sv-text-muted hover:text-sv-primary-light bg-sv-card hover:bg-sv-card-hover rounded-lg transition-all" do %>
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
              <% end %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<% if @pagy && @pagy.pages > 1 %>
  <div class="flex items-center justify-center gap-2 mt-6">
    <% if @pagy.prev %>
      <%= link_to "&larr; Previous".html_safe, admin_users_path(page: @pagy.prev), class: "sv-btn-secondary text-sm" %>
    <% end %>
    <span class="text-sv-text-muted text-sm">Page <%= @pagy.page %> of <%= @pagy.pages %></span>
    <% if @pagy.next %>
      <%= link_to "Next &rarr;".html_safe, admin_users_path(page: @pagy.next), class: "sv-btn-secondary text-sm" %>
    <% end %>
  </div>
<% end %>
