<% content_for :title, "Streams" %>

<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-white">Live Channels</h1>
    <p class="text-sv-text-muted text-sm mt-0.5"><%= @streams.count %> channels configured</p>
  </div>
  <%= link_to new_admin_stream_path, class: "sv-btn-primary flex items-center gap-2 text-sm" do %>
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
    Add Channel
  <% end %>
</div>

<div class="sv-card overflow-hidden">
  <table class="w-full">
    <thead class="border-b border-sv-border">
      <tr class="text-left">
        <th class="px-4 py-3 text-xs font-semibold text-sv-text-muted uppercase tracking-wider">Channel</th>
        <th class="px-4 py-3 text-xs font-semibold text-sv-text-muted uppercase tracking-wider hidden md:table-cell">Category</th>
        <th class="px-4 py-3 text-xs font-semibold text-sv-text-muted uppercase tracking-wider hidden lg:table-cell">CH#</th>
        <th class="px-4 py-3 text-xs font-semibold text-sv-text-muted uppercase tracking-wider">Status</th>
        <th class="px-4 py-3 text-xs font-semibold text-sv-text-muted uppercase tracking-wider">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-sv-border">
      <% @streams.each do |stream| %>
        <tr class="hover:bg-sv-card-hover/30 transition-colors">
          <td class="px-4 py-3">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-lg bg-sv-primary/10 border border-sv-border flex items-center justify-center flex-shrink-0">
                <span class="text-sm font-bold text-sv-primary-light"><%= stream.name[0..1].upcase %></span>
              </div>
              <div>
                <p class="text-sv-text font-medium text-sm"><%= stream.name %></p>
                <p class="text-sv-text-muted text-xs truncate max-w-48"><%= stream.hls_url %></p>
              </div>
            </div>
          </td>
          <td class="px-4 py-3 text-sv-text-muted text-sm hidden md:table-cell"><%= stream.category %></td>
          <td class="px-4 py-3 text-sv-text-muted text-sm hidden lg:table-cell"><%= stream.channel_number || "—" %></td>
          <td class="px-4 py-3">
            <div class="flex flex-col gap-1">
              <% if stream.is_live? %>
                <span class="sv-badge-live text-xs">LIVE</span>
              <% else %>
                <span class="sv-badge bg-sv-text-muted/20 text-sv-text-muted text-xs">Offline</span>
              <% end %>
              <% unless stream.is_active? %>
                <span class="sv-badge bg-sv-accent/20 text-sv-accent text-xs">Inactive</span>
              <% end %>
            </div>
          </td>
          <td class="px-4 py-3">
            <div class="flex items-center gap-2">
              <%= link_to admin_stream_path(stream), class: "p-1.5 text-sv-text-muted hover:text-sv-text bg-sv-card hover:bg-sv-card-hover rounded-lg transition-all" do %>
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
              <% end %>
              <%= link_to edit_admin_stream_path(stream), class: "p-1.5 text-sv-text-muted hover:text-sv-primary-light bg-sv-card hover:bg-sv-card-hover rounded-lg transition-all" do %>
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
              <% end %>
              <%= button_to admin_stream_path(stream), method: :delete,
                  class: "p-1.5 text-sv-text-muted hover:text-sv-accent bg-sv-card hover:bg-sv-card-hover rounded-lg transition-all",
                  data: { turbo_confirm: "Delete #{stream.name}?" },
                  form: { data: { turbo_confirm: "Delete #{stream.name}?" } } do %>
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
              <% end %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
