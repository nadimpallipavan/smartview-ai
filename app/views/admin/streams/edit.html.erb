<% content_for :title, "Edit — #{@stream.name}" %>

<div class="flex items-center gap-3 mb-6">
  <%= link_to admin_streams_path, class: "text-sv-text-muted hover:text-sv-text transition-colors" do %>
    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
  <% end %>
  <h1 class="text-2xl font-bold text-white">Edit: <%= @stream.name %></h1>
</div>

<div class="sv-card p-6">
  <%= form_with model: [:admin, @stream], class: "w-full" do |f| %>
    <%= render "admin/streams/form", f: f, stream: @stream %>
  <% end %>
</div>
